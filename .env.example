# LIBRUM Backend — Configuration
# Copier en .env et remplir les valeurs

# Serveur
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://librum_user:password@localhost:5432/librum_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_key_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_very_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=librum@example.com
SMTP_PASS=your_app_password
EMAIL_FROM=LIBRUM <noreply@librum.io>

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+33xxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx

# IA (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# Storage (AWS S3 / Cloudflare R2)
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=librum-uploads

# Impression (TheBookEdition)
TBE_API_KEY=your_tbe_key
TBE_API_URL=https://api.thebookedition.com/v1

# Sécurité
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ENCRYPTION_KEY=32_char_key_for_address_encryption

# Fingerprint (anti-fraude)
FINGERPRINT_API_KEY=your_fingerprint_key
